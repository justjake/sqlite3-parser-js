{
  "name": "sqlite3-parser",
  "version": "0.1.0",
  "description": "Build a JS SQL parser by ingesting machine-readable dumps from the patched lemon and mkkeywordhash tools.",
  "homepage": "https://github.com/justjake/sqlite3-parser-js#readme",
  "bugs": {
    "url": "https://github.com/justjake/sqlite3-parser-js/issues"
  },
  "license": "MIT",
  "author": {
    "name": "Jake Teton-Landis",
    "url": "https://jake.tl"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/justjake/sqlite3-parser-js.git"
  },
  "bin": {
    "sqlite3-parser": "dist/bin/sqlite3-parser.js",
    "sqlite3-tokenizer": "dist/bin/sqlite3-tokenizer.js"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./dist/generated/current.js",
  "types": "./dist/generated/current.d.ts",
  "exports": {
    ".": {
      "types": "./dist/generated/current.d.ts",
      "default": "./dist/generated/current.js"
    },
    "./sqlite-*": {
      "types": "./dist/generated/*/index.d.ts",
      "default": "./dist/generated/*/index.js"
    }
  },
  "scripts": {
    "build": "bun scripts/build.ts",
    "test": "bun test",
    "fmt": "oxfmt",
    "lint": "oxlint",
    "typecheck": "tsc --noEmit",
    "vendor": "bun scripts/vendor.ts",
    "diff:ast": "bun scripts/diff-ast.ts",
    "coverage:ast": "bun scripts/ast-coverage.ts"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "oxfmt": "^0.45.0",
    "oxlint": "^1.60.0",
    "typebox": "1.1.28",
    "typescript": "^6.0.3"
  }
}
