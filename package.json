{
  "name": "sqlite3-parser",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Build a JS SQL parser by ingesting machine-readable dumps from the patched lemon and mkkeywordhash tools.",
  "main": "./dist/generated/current.js",
  "types": "./dist/generated/current.d.ts",
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types":   "./dist/generated/current.d.ts",
      "default": "./dist/generated/current.js"
    },
    "./sqlite-*": {
      "types":   "./dist/generated/*/index.d.ts",
      "default": "./dist/generated/*/index.js"
    }
  },
  "scripts": {
    "build": "bun scripts/build.ts",
    "test": "bun test",
    "typecheck": "tsc --noEmit",
    "vendor": "bun scripts/vendor.ts",
    "diff:ast": "bun scripts/diff-ast.ts",
    "coverage:ast": "bun scripts/ast-coverage.ts"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "typebox": "1.1.28",
    "typescript": "^6.0.3"
  }
}
