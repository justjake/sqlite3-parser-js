{
  "name": "sqlite3-parser",
  "version": "0.3.0",
  "description": "Build a JS SQL parser by ingesting machine-readable dumps from the patched lemon and mkkeywordhash tools.",
  "homepage": "https://github.com/justjake/sqlite3-parser-js#readme",
  "bugs": {
    "url": "https://github.com/justjake/sqlite3-parser-js/issues"
  },
  "license": "MIT",
  "author": {
    "name": "Jake Teton-Landis",
    "url": "https://jake.tl"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/justjake/sqlite3-parser-js.git"
  },
  "bin": {
    "sqlite3-parser": "dist/bin/sqlite3-parser.js",
    "sqlite3-tokenizer": "dist/bin/sqlite3-tokenizer.js"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./dist/generated/current.js",
  "types": "./dist/generated/current.d.ts",
  "exports": {
    ".": {
      "types": "./dist/generated/current.d.ts",
      "default": "./dist/generated/current.js"
    },
    "./traverse": {
      "types": "./dist/src/ast/traverse.d.ts",
      "default": "./dist/src/ast/traverse.js"
    },
    "./sqlite-*": {
      "types": "./dist/generated/*/index.d.ts",
      "default": "./dist/generated/*/index.js"
    }
  },
  "scripts": {
    "build": "bun run build:gen && bun run build:bundle",
    "build:gen": "make gen",
    "build:bundle": "bun scripts/build.ts",
    "test": "bun test --path-ignore-patterns='vendor/**'",
    "fmt": "oxfmt",
    "lint": "oxlint",
    "typecheck": "tsc --noEmit",
    "vendor": "bun scripts/vendor.ts",
    "diff:ast": "bun scripts/diff-ast.ts",
    "coverage:ast": "bun scripts/ast-coverage.ts",
    "bench": "bun scripts/bench.ts",
    "bench:compare": "make liteparser-wasm && bun scripts/bench-compare.ts",
    "prof": "bun scripts/prof.ts",
    "dist-test": "bun scripts/dist-test.ts",
    "dist-test:build": "bun scripts/dist-test.ts --build"
  },
  "devDependencies": {
    "@appland/sql-parser": "^1.5.1",
    "@guanmingchiu/sqlparser-ts": "^0.61.1",
    "@types/bun": "latest",
    "mitata": "^1.0.34",
    "node-sql-parser": "^5.4.0",
    "oxfmt": "^0.45.0",
    "oxlint": "^1.60.0",
    "pgsql-ast-parser": "^12.0.2",
    "sqlite-parser": "^1.0.1",
    "typebox": "1.1.28",
    "typescript": "^6.0.3"
  }
}
