{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "claude-lemon/keywords.dev/v1",
  "title": "keywords.dev",
  "type": "object",
  "required": [
    "meta",
    "keywords"
  ],
  "properties": {
    "meta": {
      "type": "object",
      "required": [
        "sourceFile",
        "schemaVersion",
        "keywordCount",
        "maskFlags"
      ],
      "properties": {
        "sourceFile": {
          "type": "string"
        },
        "schemaVersion": {
          "type": "integer"
        },
        "keywordCount": {
          "type": "integer"
        },
        "maskFlags": {
          "type": "object",
          "patternProperties": {
            "^.*$": {
              "type": "integer"
            }
          }
        }
      },
      "additionalProperties": true
    },
    "keywords": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "name",
          "tokenName",
          "priority",
          "mask",
          "flags"
        ],
        "properties": {
          "name": {
            "type": "string"
          },
          "tokenName": {
            "type": "string"
          },
          "priority": {
            "type": "integer"
          },
          "mask": {
            "type": "integer"
          },
          "flags": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            }
          }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}
