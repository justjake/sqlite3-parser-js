{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "sqlite3-parser/v1/parser.prod",
  "title": "parser.prod",
  "type": "object",
  "required": ["constants", "tables", "symbols", "rules"],
  "properties": {
    "constants": {
      "type": "object",
      "required": [
        "YYNSTATE",
        "YYNRULE",
        "YYNTOKEN",
        "YYNSYMBOL",
        "YY_MAX_SHIFT",
        "YY_MIN_SHIFTREDUCE",
        "YY_MAX_SHIFTREDUCE",
        "YY_ERROR_ACTION",
        "YY_ACCEPT_ACTION",
        "YY_NO_ACTION",
        "YY_MIN_REDUCE",
        "YY_MAX_REDUCE",
        "YY_ACTTAB_COUNT",
        "YY_SHIFT_COUNT",
        "YY_REDUCE_COUNT",
        "YYWILDCARD",
        "YYFALLBACK"
      ],
      "properties": {
        "YYNSTATE": {
          "type": "integer"
        },
        "YYNRULE": {
          "type": "integer"
        },
        "YYNTOKEN": {
          "type": "integer"
        },
        "YYNSYMBOL": {
          "type": "integer"
        },
        "YY_MAX_SHIFT": {
          "type": "integer"
        },
        "YY_MIN_SHIFTREDUCE": {
          "type": "integer"
        },
        "YY_MAX_SHIFTREDUCE": {
          "type": "integer"
        },
        "YY_ERROR_ACTION": {
          "type": "integer"
        },
        "YY_ACCEPT_ACTION": {
          "type": "integer"
        },
        "YY_NO_ACTION": {
          "type": "integer"
        },
        "YY_MIN_REDUCE": {
          "type": "integer"
        },
        "YY_MAX_REDUCE": {
          "type": "integer"
        },
        "YY_ACTTAB_COUNT": {
          "type": "integer"
        },
        "YY_SHIFT_COUNT": {
          "type": "integer"
        },
        "YY_REDUCE_COUNT": {
          "type": "integer"
        },
        "YYWILDCARD": {
          "type": "integer"
        },
        "YYFALLBACK": {
          "anyOf": [
            {
              "type": "number",
              "const": 0
            },
            {
              "type": "number",
              "const": 1
            }
          ]
        }
      },
      "additionalProperties": false
    },
    "tables": {
      "type": "object",
      "required": ["yy_action", "yy_lookahead", "yy_shift_ofst", "yy_reduce_ofst", "yy_default"],
      "properties": {
        "yy_action": {
          "type": "array",
          "items": {
            "type": "integer"
          }
        },
        "yy_lookahead": {
          "type": "array",
          "items": {
            "type": "integer",
            "minimum": 0,
            "title": "SymbolId"
          }
        },
        "yy_shift_ofst": {
          "type": "array",
          "items": {
            "type": "integer"
          }
        },
        "yy_reduce_ofst": {
          "type": "array",
          "items": {
            "type": "integer"
          }
        },
        "yy_default": {
          "type": "array",
          "items": {
            "type": "integer"
          }
        },
        "yyFallback": {
          "type": "array",
          "items": {
            "type": "integer",
            "minimum": 0,
            "title": "TokenId"
          }
        }
      },
      "additionalProperties": false
    },
    "symbols": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "isTerminal"],
        "properties": {
          "name": {
            "type": "string"
          },
          "isTerminal": {
            "type": "boolean"
          }
        },
        "additionalProperties": false
      }
    },
    "rules": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["lhs", "lhsName", "rhs", "doesReduce"],
        "properties": {
          "lhs": {
            "type": "integer",
            "minimum": 0,
            "title": "SymbolId"
          },
          "lhsName": {
            "type": "string"
          },
          "rhs": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "symbol": {
                  "type": "integer",
                  "minimum": 0,
                  "title": "SymbolId"
                },
                "multi": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "required": ["symbol"],
                    "properties": {
                      "symbol": {
                        "type": "integer",
                        "minimum": 0,
                        "title": "SymbolId"
                      }
                    },
                    "additionalProperties": false
                  }
                }
              },
              "additionalProperties": false
            }
          },
          "doesReduce": {
            "type": "boolean"
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
