# Common Table Expressions: WITH RECURSIVE and AS [NOT] MATERIALIZED.

hash-threshold 8

statement ok
CREATE TABLE t1(a INTEGER, b INTEGER)

# #344 with ::= WITH RECURSIVE wqlist — fires only when the `with`
# non-terminal is consumed by DELETE/UPDATE/INSERT (select has inline
# WITH-aware rules that never reduce through `with`).
statement ok
CREATE TABLE t_cte(a INTEGER, b INTEGER)

statement ok
WITH RECURSIVE counter(n) AS (
  SELECT 1
  UNION ALL
  SELECT n + 1 FROM counter WHERE n < 10
)
DELETE FROM t_cte WHERE a IN (SELECT n FROM counter)

statement ok
WITH RECURSIVE counter(n) AS (SELECT 1 UNION ALL SELECT n + 1 FROM counter WHERE n < 5)
UPDATE t_cte SET b = 1 WHERE a IN (SELECT n FROM counter)

statement ok
WITH RECURSIVE counter(n) AS (SELECT 1 UNION ALL SELECT n + 1 FROM counter WHERE n < 5)
INSERT INTO t_cte(a, b) SELECT n, n FROM counter

# Also exercise the non-recursive `with` form with DELETE so the
# non-RECURSIVE `with ::= WITH wqlist` rule fires.
statement ok
WITH counter2(n) AS (SELECT 1)
DELETE FROM t_cte WHERE a IN (SELECT n FROM counter2)

# Keep a SELECT-shaped WITH RECURSIVE for completeness — uses the
# inlined select-with rule (#510), not #344.
statement ok
WITH RECURSIVE counter(n) AS (
  SELECT 1
  UNION ALL
  SELECT n + 1 FROM counter WHERE n < 10
)
SELECT * FROM counter

# #346 wqas ::= AS MATERIALIZED
statement ok
WITH c1 AS MATERIALIZED (SELECT a FROM t1)
SELECT * FROM c1

# #347 wqas ::= AS NOT MATERIALIZED
statement ok
WITH c2 AS NOT MATERIALIZED (SELECT a FROM t1)
SELECT * FROM c2

# RECURSIVE + materialization combined — exercises wqlist over both arms.
statement ok
WITH RECURSIVE
  base AS MATERIALIZED (SELECT 1 AS n),
  rec(n) AS NOT MATERIALIZED (
    SELECT n FROM base
    UNION ALL
    SELECT n + 1 FROM rec WHERE n < 5
  )
SELECT * FROM rec
