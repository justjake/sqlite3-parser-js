{
  // Build tsconfig — emits .js + .d.ts for the shippable set of
  // modules (src/ + generated/ + bin/).  Test files, build scripts,
  // and dev-only generator files are excluded so downstream consumers
  // don't accidentally pick up internal tooling.
  //
  // `allowImportingTsExtensions` is off for emit because tsc's output
  // references `.d.ts` via Node's usual extension rewriting, and
  // leaving `.ts` specifiers in the emitted declarations would trip
  // up downstream consumers.  `rewriteRelativeImportExtensions` makes
  // tsc rewrite `.ts` → `.js` in emitted .js files so they resolve
  // under Node's ESM module loader.  The base tsconfig keeps the
  // `.ts`-style imports on for dev ergonomics; we override just for
  // this pass.
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "noEmit": false,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "allowImportingTsExtensions": false,
    "rewriteRelativeImportExtensions": true,
    "outDir": "./dist",
    "rootDir": "."
  },
  "include": ["src/**/*.ts", "generated/**/*.ts", "bin/**/*.ts"],
  "exclude": [
    "node_modules",
    "vendor",
    "test/**",
    "scripts/**",
    "build/**",
    "dist/**",
    "generated/template/**"
  ]
}
